{
  "rewrites": [
    { "source": "/quiz",   "destination": "/index.html" },
    { "source": "/result", "destination": "/index.html" },
    { "source": "/signup", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
