{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "ui_kits/planningbox/**",
              "ui_kits/potenlab/**",
              "ui_kits/potenlab/partnership/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {},
    "tokens": [
      "--admin-pad",
      "--admin-sidebar-w",
      "--container-cols",
      "--container-gutter",
      "--container-max",
      "--dur-base",
      "--dur-fast",
      "--dur-slow",
      "--ease-standard",
      "--radius-2xl",
      "--radius-full",
      "--radius-lg",
      "--radius-md",
      "--radius-sm",
      "--radius-xl",
      "--shadow-card",
      "--shadow-card-hover",
      "--shadow-cta",
      "--shadow-cta-hover",
      "--shadow-lg",
      "--shadow-md",
      "--shadow-sm",
      "--shadow-violet",
      "--shadow-xl",
      "--space-1",
      "--space-10",
      "--space-12",
      "--space-16",
      "--space-2",
      "--space-3",
      "--space-4",
      "--space-5",
      "--space-6",
      "--space-7",
      "--space-8",
      "--space-9"
    ],
    "tokenKinds": {
      "--space-1": "spacing",
      "--space-2": "spacing",
      "--space-3": "spacing",
      "--space-4": "spacing",
      "--space-5": "spacing",
      "--space-6": "spacing",
      "--space-7": "spacing",
      "--space-8": "spacing",
      "--space-9": "spacing",
      "--space-10": "spacing",
      "--space-12": "spacing",
      "--space-16": "spacing",
      "--container-max": "spacing",
      "--container-gutter": "spacing",
      "--container-cols": "other",
      "--admin-sidebar-w": "spacing",
      "--admin-pad": "spacing",
      "--radius-sm": "radius",
      "--radius-md": "radius",
      "--radius-lg": "radius",
      "--radius-xl": "radius",
      "--radius-2xl": "radius",
      "--radius-full": "radius",
      "--shadow-sm": "shadow",
      "--shadow-md": "shadow",
      "--shadow-lg": "shadow",
      "--shadow-xl": "shadow",
      "--shadow-card": "shadow",
      "--shadow-card-hover": "shadow",
      "--shadow-cta": "shadow",
      "--shadow-cta-hover": "shadow",
      "--shadow-violet": "shadow",
      "--ease-standard": "other",
      "--dur-fast": "other",
      "--dur-base": "other",
      "--dur-slow": "other"
    },
    "fontFamilies": []
  }
}